# Firebase Admin service account
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-firebase-project-id.iam.gserviceaccount.com

# When copying from the JSON private_key, replace real newlines with \n
# Example:
# "-----BEGIN PRIVATE KEY-----\nABC123...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_LINES_HERE\n-----END PRIVATE KEY-----\n"

# Optional: base URL used as a fallback when building share links
# e.g. https://quick-note-share.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000